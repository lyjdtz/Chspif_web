---
import BaseLayout from '../layouts/Layout.astro';
import 'animate.css';
---

<BaseLayout>
  <div class="min-h-screen flex flex-col items-center justify-center p-4">
    <div class="w-full max-w-4xl">
      
      <!-- 页面标题 -->
      <div class="text-center mb-12 animate__animated animate__fadeIn">
        <h1 class="text-4xl font-bold text-white mb-4">服务器规则</h1>
        <p class="text-xl text-white/80">了解服务器内规则以更好地在服务器中游玩</p>
      </div>

      <div class="space-y-12">
        
        <!-- 规则1: 尊重社区成员 -->
        <section class="bg-white/20 backdrop-blur-md rounded-3xl p-8 border border-white/30 animate__animated animate__fadeInUp">
          <div class="flex items-center mb-6">
            <div class="w-10 h-10 rounded-full bg-blue-500/30 flex items-center justify-center mr-4">
              <span class="text-lg font-bold text-blue-400">1</span>
            </div>
            <h3 class="text-2xl font-semibold text-white">尊重社区成员</h3>
          </div>
          
          <p class="text-lg text-white/80 mb-6">我们致力于建立一个友善且尊重所有人的游戏环境。以下行为严厉禁止：</p>
          
          <ul class="space-y-3 text-white/90">
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              禁止歧视言论：避免基于种族、性别、年龄的歧视性话语
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              严禁骚扰与欺凌：不得实施任何形式的骚扰、欺凌及人身攻击
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              保护隐私：不可泄露他人个人信息
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              禁止刷屏：不允许重复发送相同或相似消息
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              禁止不良内容：不准发布不当性内容或裸露图片
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              禁止恶意信息：不传播恶意软件、病毒，不从事欺诈活动
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              反对虚假信息：不得散布虚假信息或诽谤他人
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              杜绝负面内容：不鼓励发布任何可能诱导自伤或伤害他人的信息
            </li>
          </ul>
        </section>

        <!-- 规则2: 维持服务器稳定 -->
        <section class="bg-white/20 backdrop-blur-md rounded-3xl p-8 border border-white/30 animate__animated animate__fadeInUp">
          <div class="flex items-center mb-6">
            <div class="w-10 h-10 rounded-full bg-blue-500/30 flex items-center justify-center mr-4">
              <span class="text-lg font-bold text-blue-400">2</span>
            </div>
            <h3 class="text-2xl font-semibold text-white">维持服务器稳定</h3>
          </div>
          
          <p class="text-lg text-white/80 mb-4">请勿执行消耗服务器资源的极端行为：</p>
          
          <ul class="space-y-3 text-white/90">
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              实体数量控制：避免积累过多实体，不建设导致服务器过载的设施
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              合理安排逻辑：优化您的设计网络，减少同时运行的逻辑节点数量
            </li>
          </ul>
        </section>

        <!-- 规则3: 保护他人建筑 -->
        <section class="bg-white/20 backdrop-blur-md rounded-3xl p-8 border border-white/30 animate__animated animate__fadeInUp">
          <div class="flex items-center mb-6">
            <div class="w-10 h-10 rounded-full bg-blue-500/30 flex items-center justify-center mr-4">
              <span class="text-lg font-bold text-blue-400">3</span>
            </div>
            <h3 class="text-2xl font-semibold text-white">保护他人建筑</h3>
          </div>
          
          <p class="text-lg text-white/80 mb-4">尊重并守护他人的创造成果：</p>
          
          <ul class="space-y-3 text-white/90">
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              禁止破坏建筑：不得损毁或擅自改动他人建筑物
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              避免损害：不得以任何形式对他人建筑造成伤害
            </li>
          </ul>
        </section>

        <!-- 规则4: 公正游戏体验 -->
        <section class="bg-white/20 backdrop-blur-md rounded-3xl p-8 border border-white/30 animate__animated animate__fadeInUp">
          <div class="flex items-center mb-6">
            <div class="w-10 h-10 rounded-full bg-blue-500/30 flex items-center justify-center mr-4">
              <span class="text-lg font-bold text-blue-400">4</span>
            </div>
            <h3 class="text-2xl font-semibold text-white">公正游戏体验</h3>
          </div>
          
          <p class="text-lg text-white/80 mb-4">倡导公平竞争：</p>
          
          <ul class="space-y-3 text-white/90">
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              反对作弊：禁止修改游戏数据或利用漏洞
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              拒绝非法软件：不允许使用未经授权的第三方软件影响游戏
            </li>
          </ul>
        </section>

        <!-- 规则5: 尊重财产权 -->
        <section class="bg-white/20 backdrop-blur-md rounded-3xl p-8 border border-white/30 animate__animated animate__fadeInUp">
          <div class="flex items-center mb-6">
            <div class="w-10 h-10 rounded-full bg-blue-500/30 flex items-center justify-center mr-4">
              <span class="text-lg font-bold text-blue-400">5</span>
            </div>
            <h3 class="text-2xl font-semibold text-white">尊重财产权</h3>
          </div>
          
          <p class="text-lg text-white/80 mb-4">勿盗取他人财物：</p>
          
          <ul class="space-y-3 text-white/90">
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              禁止偷窃：未经允许，不得取用他人物品
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              禁止侵占：不可盗取他人的宠物或物品
            </li>
          </ul>
        </section>

        <!-- 规则6: 杜绝恶意伤害 -->
        <section class="bg-white/20 backdrop-blur-md rounded-3xl p-8 border border-white/30 animate__animated animate__fadeInUp">
          <div class="flex items-center mb-6">
            <div class="w-10 h-10 rounded-full bg-blue-500/30 flex items-center justify-center mr-4">
              <span class="text-lg font-bold text-blue-400">6</span>
            </div>
            <h3 class="text-2xl font-semibold text-white">杜绝恶意伤害</h3>
          </div>
          
          <p class="text-lg text-white/80 mb-4">不得无理由伤害玩家及其宠物：</p>
          
          <ul class="space-y-3 text-white/90">
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              反对恶意攻击：不可设置陷阱或使用爆炸物伤害他人
            </li>
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              PVP须同意：经双方同意的PVP除外
            </li>
          </ul>
        </section>

        <!-- 规则7: 促进健康创作 -->
        <section class="bg-white/20 backdrop-blur-md rounded-3xl p-8 border border-white/30 animate__animated animate__fadeInUp">
          <div class="flex items-center mb-6">
            <div class="w-10 h-10 rounded-full bg-blue-500/30 flex items-center justify-center mr-4">
              <span class="text-lg font-bold text-blue-400">7</span>
            </div>
            <h3 class="text-2xl font-semibold text-white">促进健康创作</h3>
          </div>
          
          <p class="text-lg text-white/80 mb-4">鼓励创意与自由表达，但需得体：</p>
          
          <ul class="space-y-3 text-white/90">
            <li class="flex items-start">
              <span class="text-blue-400 mr-2">•</span>
              不适当创作禁令：不可创作含有不适宜内容的像素艺术、书籍、用户名或装备名
            </li>
          </ul>
        </section>

        <!-- 总结 -->
        <section class="bg-white/20 backdrop-blur-md rounded-3xl p-8 border border-white/30 animate__animated animate__fadeInUp">
          <div class="text-center">
            <p class="text-lg text-white/90 mb-4">任何违规行为将依法处理。</p>
            <p class="text-lg text-white/90 mb-4">我们珍视您的理解与合作，共同营造Chspif的良好秩序与和谐氛围。</p>
            <p class="text-xl text-white font-semibold">祝您游戏愉快！</p>
          </div>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>