---
import BaseLayout from '../layouts/Layout.astro';
---

<BaseLayout>
  <div class="min-h-screen flex flex-col items-center justify-center p-4">
    <div class="w-full max-w-4xl">
      
      <!-- 页面标题 -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-white mb-4">为什么选择我们</h1>
      </div>


      <!-- 特点部分 -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-center mb-8 text-blue-100"></h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          
          <!-- 生电玩家友好 -->
          <div class="bg-white/20 backdrop-blur-md rounded-3xl p-6 border border-white/30">
            <div class="flex items-center mb-4">
              <div class="bg-blue-500/30 w-12 h-12 rounded-full flex items-center justify-center mr-4">
                <span class="text-2xl">🐱</span>
              </div>
              <h3 class="text-xl font-bold text-blue-200">生电玩家友好</h3>
            </div>
            <p class="text-blue-100">
              Fabric+Carpet,包含部分优化和功能mod <br>
              不添加任何原版以外的功能,服务端环境易复刻,一切为原版服务
            </p>
          </div>

          <!-- 极优配置 -->
          <div class="bg-white/20 backdrop-blur-md rounded-3xl p-6 border border-white/30">
            <div class="flex items-center mb-4">
              <div class="bg-blue-500/30 w-12 h-12 rounded-full flex items-center justify-center mr-4">
                <span class="text-2xl">🔌</span>
              </div>
              <h3 class="text-xl font-bold text-blue-200">硬件配置</h3>
            </div>
            <p class="text-blue-100">
              满血14900kf <br>
              BGP三线机房 <br>
              保证服务器运行稳定和连接流畅
            </p>
          </div>

          <!-- 氛围友好 -->
          <div class="bg-white/20 backdrop-blur-md rounded-3xl p-6 border border-white/30">
            <div class="flex items-center mb-4">
              <div class="bg-blue-500/30 w-12 h-12 rounded-full flex items-center justify-center mr-4">
                <span class="text-2xl">🍃</span>
              </div>
              <h3 class="text-xl font-bold text-blue-200">氛围友好</h3>
            </div>
            <p class="text-blue-100">
              玩家氛围友好,交流欲望高,素质整体优越,平均在线时间长
            </p>
          </div>

          <!-- 运维稳定 -->
          <div class="bg-white/20 backdrop-blur-md rounded-3xl p-6 border border-white/30">
            <div class="flex items-center mb-4">
              <div class="bg-blue-500/30 w-12 h-12 rounded-full flex items-center justify-center mr-4">
                <span class="text-2xl">🛡️</span>
              </div>
              <h3 class="text-xl font-bold text-blue-200">运维稳定</h3>
            </div>
            <p class="text-blue-100">
              数据每两小时一次备份,保证玩家成果得到保护和尊重 <br>
              管理人员24小时响应,服务器运维专业稳定 <br>
              服务器成立距今已六年
            </p>
          </div>

          <!-- 公益开放 -->
          <div class="bg-white/20 backdrop-blur-md rounded-3xl p-6 border border-white/30">
            <div class="flex items-center mb-4">
              <div class="bg-blue-500/30 w-12 h-12 rounded-full flex items-center justify-center mr-4">
                <span class="text-2xl">☀️</span>
              </div>
              <h3 class="text-xl font-bold text-blue-200">公益开放</h3>
            </div>
            <p class="text-blue-100">
              服务器永远不会以任何形式强制玩家付费,用爱发电
            </p>
          </div>

          <!-- 开源 -->
          <div class="bg-white/20 backdrop-blur-md rounded-3xl p-6 border border-white/30">
            <div class="flex items-center mb-4">
              <div class="bg-blue-500/30 w-12 h-12 rounded-full flex items-center justify-center mr-4">
                <span class="text-2xl">💻</span>
              </div>
              <h3 class="text-xl font-bold text-blue-200">开源</h3>
            </div>
            <p class="text-blue-100">
              大部分修改内容会开源
            </p>
          </div>

        </div>
      </section>

      <!-- 团队部分 -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-center mb-8 text-blue-100">我们的团队</h2>
        
        <!-- 团队成员卡片 -->
        <div class="flex justify-center">
          <div class="bg-white/20 backdrop-blur-md rounded-3xl p-8 border border-white/30 max-w-md w-full">
            <div class="text-center">
              
              <!-- 头像 -->
              <div class="mb-6">
                <img 
                  src="https://img.cdn1.vip/i/69294ac1d8d31_1764313793.webp" 
                  alt="兔子" 
                  class="w-32 h-32 rounded-full mx-auto border-4 border-blue-400/50"
                >
              </div>
        
              <!-- 姓名和职位 -->
              <h3 class="text-2xl font-bold text-blue-200 mb-1">兔子</h3>
              <p class="text-blue-300 mb-4">服主</p>
        
              <!-- 介绍 -->
              <div class="mb-6">
                <p class="text-blue-100 text-lg"></p>
              </div>
        
              <!-- 联系信息 -->
              <div class="flex justify-center">
                <a 
                  href="https://github.com/lyjdtz" 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="bg-blue-500/30 hover:bg-blue-500/50 transition-colors p-3 rounded-full"
                  title="访问兔子的博客"
                >
                  <svg class="w-6 h-6 text-blue-200" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                </a>
              </div>
        
            </div>
          </div>
        </div>
      </section>

      <!-- 返回首页按钮 -->
      <div class="text-center">
        <a 
          href="/" 
          class="inline-flex items-center px-6 py-3 bg-blue-500/30 hover:bg-blue-500/50 text-blue-100 font-semibold rounded-3xl border border-white/30 transition-colors"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          返回首页
        </a>
      </div>

    </div>
  </div>
</BaseLayout>