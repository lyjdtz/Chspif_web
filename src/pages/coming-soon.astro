---
import BaseLayout from '../layouts/Layout.astro';
import 'animate.css';
---

<BaseLayout>
  <div class="h-screen flex flex-col items-center justify-center text-center">
    <!-- 背景模糊层 -->
    <div class="absolute inset-0 bg-black bg-opacity-50 backdrop-filter blur-sm"></div>
    
    <!-- 内容区域 -->
    <div class="relative z-10 animate__animated animate__fadeInUp">
      <!-- 图标/装饰 -->
      <div class="mb-8">
        <div class="w-24 h-24 mx-auto bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center shadow-2xl">
          <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
      
      <!-- 主标题 -->
      <h1 class="text-6xl font-bold text-white mb-4 tracking-wider">
        暂未开放
      </h1>
      
      <!-- 副标题 -->
      <p class="text-xl text-gray-300 mb-8 max-w-md mx-auto leading-relaxed">

      </p>
      
      <!-- 返回按钮 -->
      <div class="space-y-4">
        <a 
          href="/" 
          class="inline-block bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white font-semibold py-3 px-8 rounded-full transition-all duration-300 transform hover:scale-105 shadow-lg"
        >
          返回主页
        </a>
      </div>
      
      <!-- 装饰性元素 -->
      <div class="mt-12 flex justify-center space-x-4">
        <div class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"></div>
        <div class="w-2 h-2 bg-purple-400 rounded-full animate-pulse" style="animation-delay: 0.2s;"></div>
        <div class="w-2 h-2 bg-pink-400 rounded-full animate-pulse" style="animation-delay: 0.4s;"></div>
      </div>
    </div>
  </div>
</BaseLayout>