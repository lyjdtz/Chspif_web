		<script type="module">
			document.addEventListener('DOMContentLoaded', () => {
				const splineViewers = document.querySelectorAll('spline-viewer');
				splineViewers.forEach(splineViewer => {
					const logo = splineViewer.shadowRoot.querySelector('#logo');
					if (!logo) return;
					logo.remove();
				});
			});
		</script>
